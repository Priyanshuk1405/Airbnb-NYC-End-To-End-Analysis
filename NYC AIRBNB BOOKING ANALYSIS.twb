      <aliases enabled='yes' />
      <column caption='Total Listings' datatype='integer' name='[Calculation_1535537434275840]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([listing_id])' />
      </column>
      <column caption='Avg Price' datatype='real' name='[Calculation_1535537434435585]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([price])' />
      </column>
      <column caption='Avg Booked Days' datatype='real' name='[Calculation_1535537434492930]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([est_booked_days])' />
      </column>
      <column caption='Avg Occupancy Rate' datatype='real' name='[Calculation_1535537434607619]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG((365 - [availability_365])/365)*100' />
      </column>
